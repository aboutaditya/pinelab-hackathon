# ─── Pine Labs Autonomous Settlement Auditor ───
# Copy this file to .env and fill in the values.

# ── LLMs / AWS ──
GOOGLE_API_KEY=AIzaSy...
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=secret...
AWS_DEFAULT_REGION=us-east-1
AWS_SESSION_TOKEN=          # required for temporary/STS/SSO credentials
AWS_ACCOUNT_ID=             # optional — auto-detected via STS if blank

# ── PostgreSQL ──
POSTGRES_DB=pinelabs
POSTGRES_USER=pinelabs
POSTGRES_PASSWORD=pinelabs_secret

# ── Django ──
DJANGO_SECRET_KEY=super-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# ── Redis ──
REDIS_URL=redis://redis:6379/0
